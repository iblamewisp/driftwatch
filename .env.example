# Required — generate with: python -m cli generate-key
DRIFTWATCH_KEY_HASH=

# Database
DATABASE_URL=postgresql+asyncpg://driftwatch:driftwatch@postgres:5432/driftwatch

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI (used only by CLI golden-set add — never logged or stored by the proxy)
# OPENAI_API_KEY=sk-...

# Sampling (every Nth response is sent to the evaluator worker)
SAMPLING_RATE=10

# Golden set
GOLDEN_SET_MODE=auto         # auto | manual
GOLDEN_SET_WARMUP=100        # only used when mode=auto

# Drift detection
DRIFT_THRESHOLD=0.15                  # 15% relative drop from baseline triggers alert

# Clustering (BIRCH)
BIRCH_THRESHOLD=0.25    # max cluster radius — lower = tighter clusters, higher = looser

# Notifications
NOTIFICATION_CHANNEL=none    # none | telegram | webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
WEBHOOK_URL=
WEBHOOK_SECRET=

# Monitoring
ENABLE_METRICS=true

# Embedding service
EMBEDDING_SERVICE_URL=http://litserve:8001

# Vector backend
VECTOR_BACKEND=pgvector      # pgvector | qdrant
QDRANT_URL=                  # http://qdrant:6333 — only needed if VECTOR_BACKEND=qdrant
QDRANT_COLLECTION=driftwatch
